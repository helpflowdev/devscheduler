# Copy to .streamlit/secrets.toml (gitignored) for local Postgres testing,
# or paste these keys into Streamlit Community Cloud → Settings → Secrets.
#
# Omit DATABASE_URL entirely to use the local SQLite file instead.

DATABASE_URL = "postgresql://user:password@host:5432/dbname"

# App-open password (view access). Optional.
SCHEDULER_PASSWORD = "change-me"

# Extra password asked before editing / adding / managing people.
# Per session by default (re-asked on refresh / new tab).
SCHEDULER_EDIT_PASSWORD = "change-me-too"
# Optional: also expire the edit unlock after N idle minutes (e.g. 10).
# Leave unset for session-long (recommended for a trusted team).
# SCHEDULER_EDIT_TTL_MIN = "10"
